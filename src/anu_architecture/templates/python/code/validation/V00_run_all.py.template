"""V00: Run all V## scripts in numeric order."""
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).parent
scripts = sorted([p for p in HERE.iterdir()
                  if p.name.startswith("V")
                  and p.suffix == ".py"
                  and p.name != "V00_run_all.py"
                  and p.name[1:3].isdigit()],
                 key=lambda p: int(p.name[1:3]))

for s in scripts:
    print(f"  V## {s.name}")
    r = subprocess.run([sys.executable, str(s)])
    if r.returncode != 0:
        sys.exit(r.returncode)
