# Master orchestrator for {{ project_name }}
# Discovers L##/P##/V##/M##/A##/O## scripts and sources them in order.
for (phase in strsplit('SLPVMAOVO', '')[[1]]) {
  dir <- file.path('code', list('S'='setup','L'='loading','P'='processing',
                                'V'='validation','M'='manual','A'='analysis',
                                'O'='outputs','E'='exploration')[[phase]])
  scripts <- sort(list.files(dir, pattern=paste0('^', phase, '[0-9]{2}_.*\\.R$'), full.names=TRUE))
  for (s in scripts) { cat(phase, basename(s), '\n'); source(s) }
}
